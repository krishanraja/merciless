# ===========================================================================
# Client (Vite) — exposed to the browser bundle, must be prefixed with VITE_
# ===========================================================================
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_STRIPE_PRICE_ID=price_1TJEo24w6vAdI2o57Rz8Cp3X

# ===========================================================================
# Supabase Edge Function secrets (set via `supabase secrets set`)
# Referenced by supabase/functions/* via Deno.env.get(). These are NOT loaded
# from this file at runtime — they are listed here for reference only.
# ===========================================================================

# Supabase project URL — used by edge functions to create a server client
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Supabase service-role key — full DB access, server-side only
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Google Gemini API key — _shared/llm.ts (primary LLM)
GEMINI_API_KEY=your_gemini_api_key
# OpenAI API key — _shared/llm.ts (LLM fallback) and transcribe-date
OPENAI_API_KEY=your_openai_api_key
# Stripe secret key — create-checkout, stripe-webhook
STRIPE_SECRET_KEY=sk_live_...
# Stripe webhook signing secret — stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe price ID — create-checkout (defaults to a hardcoded price if unset)
STRIPE_PRICE_ID=price_1TJEo24w6vAdI2o57Rz8Cp3X

# ===========================================================================
# Attribution (the ONLY warehouse credential this app holds). Set as a Supabase
# edge-function secret. The app POSTs funnel + revenue events to the Mindmaker OS
# warehouse ingestion front door; it never holds the warehouse service-role key.
# ===========================================================================
# Shared secret that authenticates this app to the OS warehouse ingest-attribution
# function (x-attribution-secret header). Must match the value set on the warehouse.
ATTRIBUTION_INGEST_SECRET=your_attribution_ingest_secret
# Optional override of the warehouse ingest URL (defaults to the OS warehouse).
ATTRIBUTION_INGEST_URL=https://gojpffsrxybbpbdzzrvs.supabase.co/functions/v1/ingest-attribution
